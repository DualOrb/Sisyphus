# ─── LLM Configuration ───────────────────────────────────────
LLM_BASE_URL=https://openrouter.ai/api/v1    # Or http://halo.local:8080/v1 for local
LLM_API_KEY=sk-or-...
LLM_MODEL=qwen/qwen3-30b-a3b
LLM_FALLBACK_URL=https://openrouter.ai/api/v1
LLM_FALLBACK_API_KEY=sk-or-...
LLM_FALLBACK_MODEL=anthropic/claude-sonnet-4-6

# ─── Dispatch Credentials (Cognito) ──────────────────────────
DISPATCH_API_URL=https://api.dispatch.valleyeats.ca
DISPATCH_WS_URL=wss://ewso6i418g.execute-api.us-east-1.amazonaws.com/prod
DISPATCH_USERNAME=sisyphus@valleyeats.ca
DISPATCH_PASSWORD=

# ─── AWS (DynamoDB direct access + Secrets Manager) ──────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SECRETS_ARN=vendorportal/credentials

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── PostgreSQL (Sisyphus own database) ──────────────────────
POSTGRES_URL=postgresql://sisyphus:password@localhost:5432/sisyphus

# ─── DynaClone (MySQL read-only replica) ─────────────────────
# Credentials loaded from AWS Secrets Manager at runtime
# Host: iris.valleyeats.ca | DB: admin_dynaclone

# ─── Temporal ────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=sisyphus-workers

# ─── Chrome (Headless browser for dispatch UI) ───────────────
CHROME_CDP_URL=ws://localhost:9222

# ─── Business Hours ──────────────────────────────────────────
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=22:00
BUSINESS_TIMEZONE=America/Edmonton

# ─── Observability ───────────────────────────────────────────
LOG_LEVEL=info
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sisyphus

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"],
      "@config/*": ["./src/config/*"],
      "@ontology/*": ["./src/ontology/*"],
      "@agents/*": ["./src/agents/*"],
      "@execution/*": ["./src/execution/*"],
      "@guardrails/*": ["./src/guardrails/*"],
      "@memory/*": ["./src/memory/*"],
      "@shift/*": ["./src/shift/*"],
      "@llm/*": ["./src/llm/*"],
      "@tools/*": ["./src/tools/*"],
      "@lib/*": ["./src/lib/*"],
      "@events/*": ["./src/events/*"],
      "@db/*": ["./db/*"]
    }
  },
  "include": ["src/**/*.ts", "db/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
